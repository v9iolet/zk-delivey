<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cl.dao.KuaidiyuanDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.cl.entity.KuaidiyuanEntity" id="kuaidiyuanMap">
        <result property="touxiang" column="touxiang"/>
        <result property="kuaidiyuanzhanghao" column="kuaidiyuanzhanghao"/>
        <result property="mima" column="mima"/>
        <result property="kuaidiyuanxingming" column="kuaidiyuanxingming"/>
        <result property="xingbie" column="xingbie"/>
        <result property="shoujihaoma" column="shoujihaoma"/>
        <result property="gongsizhanghao" column="gongsizhanghao"/>
        <result property="gongsimingcheng" column="gongsimingcheng"/>
