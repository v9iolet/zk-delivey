<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cl.dao.DingdanxiadanDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.cl.entity.DingdanxiadanEntity" id="dingdanxiadanMap">
        <result property="fengmian" column="fengmian"/>
        <result property="fuwumingcheng" column="fuwumingcheng"/>
        <result property="fuwuleixing" column="fuwuleixing"/>
        <result property="fuwujiage" column="fuwujiage"/>
        <result property="gongsizhanghao" column="gongsizhanghao"/>
        <result property="gongsimingcheng" column="gongsimingcheng"/>
        <result property="lianxifangshi" column="lianxifangshi"/>
        <result property="dingdanbianhao" column="dingdanbianhao"/>
        <result property="xiadanzhanghao" column="xiadanzhanghao"/>
        <result property="xiadanren" column="xiadanren"/>
        <result property="lianxidianhua" column="lianxidianhua"/>
        <result property="huowumingcheng" column="huowumingcheng"/>
        <result property="huowumiaoshu" column="huowumiaoshu"/>
        <result property="fahuodizhi" column="fahuodizhi"/>
        <result property="shouhuodizhi" column="shouhuodizhi"/>
        <result property="shoujianrenxingming" column="shoujianrenxingming"/>
        <result property="shoujihaoma" column="shoujihaoma"/>
        <result property="xiadanshijian" column="xiadanshijian"/>
        <result property="ispay" column="ispay"/>
        <result property="dingdanzhuangtai" column="dingdanzhuangtai"/>
    </resultMap>

    <select id="selectListView"
		resultType="com.cl.entity.view.DingdanxiadanView" >

		SELECT  dingdanxiadan.* FROM dingdanxiadan  dingdanxiadan 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.cl.entity.view.DingdanxiadanView" >
		SELECT * FROM dingdanxiadan  dingdanxiadan <where> 1=1 ${ew.sqlSegment}</where>
	</select>



    <select id="selectValue" resultType="map" >
        SELECT ${params.xColumn}, ROUND(sum(${params.yColumn}),1) total FROM dingdanxiadan
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.xColumn}
        limit 10
    </select>

    <select id="selectTimeStatValue" resultType="map" >
        <if test = 'params.timeStatType == "日"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m-%d') ${params.xColumn}, sum(${params.yColumn}) total FROM dingdanxiadan
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m-%d')
        </if>
        <if test = 'params.timeStatType == "月"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m') ${params.xColumn}, sum(${params.yColumn}) total FROM dingdanxiadan
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m')
        </if>
        <if test = 'params.timeStatType == "年"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y') ${params.xColumn}, sum(${params.yColumn}) total FROM dingdanxiadan
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y')
        </if>
    </select>

    <select id="selectGroup" resultType="map" >
        SELECT ${params.column} , count(1) total FROM dingdanxiadan
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.column}
        limit 10
    </select>



</mapper>
